{
  "manifest_version": 3,
  "name": "Akira",
  "version": "0.1.0",
  "description": "Akira — conversational AI in the side panel. Point it at your local or hosted Akira app.",
  "permissions": ["storage", "sidePanel"],
  "host_permissions": ["http://localhost/*", "http://127.0.0.1/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Akira"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}
